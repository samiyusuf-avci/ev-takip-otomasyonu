# Sunucu Port Yapılandırması
PORT=5000

# Güvenlik Yapılandırması (JWT Şifreleme Anahtarı)
JWT_SECRET=your_jwt_secret_key_here

# CORS / İzin Verilen Frontend URL'si
FRONTEND_URL=http://localhost:5173

# Veritabanı Yolu (Railway veya diğer sunucularda persistent volume path'i yazılmalıdır)
# DATABASE_PATH=/data/database.sqlite
