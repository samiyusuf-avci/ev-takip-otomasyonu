{
  "name": "ev-takip-otomasyonu",
  "version": "1.0.0",
  "description": "Akıllı Ev ve Yaşam Asistanı Otomasyonu",
  "scripts": {
    "install:backend": "npm install --prefix backend",
    "install:frontend": "npm install --prefix frontend",
    "install:all": "npm install && npm run install:backend && npm run install:all-fe",
    "install:all-fe": "npm install --prefix frontend",
    "backend": "npm start --prefix backend",
    "frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
